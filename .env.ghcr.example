# Pre-built image (GHCR) — the ONLY required value is LAN_IP.
# Copy to .env next to docker-compose.ghcr.yml, or set these as the stack's
# environment variables in Portainer / CasaOS.

# This machine's LAN IPv4 — NOT 127.0.0.1. Matter pairing + WebRTC depend on it.
LAN_IP=192.168.1.50

# --- Optional overrides (safe defaults shown) ---
# TZ=America/Sao_Paulo
# WEB_PORT=3202
# MATTER_PORT=5550
# IMAGE_OWNER=patricktd            # set to your fork (e.g. fabianosan) to run its images
# IMAGE_TAG=latest                 # pin a release, e.g. v0.5.0-beta
# GITHUB_REPO=patricktd/MatterCameras
