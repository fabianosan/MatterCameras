# Pre-built image (GHCR) — used by `docker compose -f docker-compose.ghcr.yml` on the CLI.
# CasaOS / Portainer do NOT read this file: set these in their Environment-variable UI.

# This machine's LAN IPv4 — NOT 127.0.0.1. Matter pairing + WebRTC depend on it.
LAN_IP=192.168.1.50

# Optional overrides:
# TZ=America/Sao_Paulo
# WEB_PORT=3202

# To run your own fork's images, edit the two `image:` lines in docker-compose.ghcr.yml
# (change patricktd to your GitHub user).
