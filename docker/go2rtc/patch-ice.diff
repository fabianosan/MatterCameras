diff --git a/pkg/webrtc/api.go b/pkg/webrtc/api.go
index a4da479..c8f1a02 100644
--- a/pkg/webrtc/api.go
+++ b/pkg/webrtc/api.go
@@ -2,6 +2,7 @@ package webrtc
 
 import (
 	"net"
+	"time"
 
 	"github.com/AlexxIT/go2rtc/pkg/core"
 	"github.com/AlexxIT/go2rtc/pkg/xnet"
@@ -45,6 +46,18 @@ func NewServerAPI(network, address string, filters *Filters) (*webrtc.API, error
 	// fix https://github.com/pion/webrtc/pull/2407
 	s.SetDTLSInsecureSkipHelloVerify(true)
 
+	// SmartThings/Matter clients on LAN need ~25ms for STUN binding responses,
+	// but pion's default MaxBindingRequests (7) is exhausted within ~11ms when
+	// the ICE agent bursts pings across all candidate pairs at connect time.
+	// Raise the limit so pairs remain InProgress until a response arrives.
+	s.SetICEMaxBindingRequests(100)
+
+	// When the bridge becomes ICE controlling (remote offer marked ice-lite),
+	// nominate LAN host pairs immediately instead of waiting on srflx/relay.
+	s.SetHostAcceptanceMinWait(0)
+	s.SetSrflxAcceptanceMinWait(24 * time.Hour)
+	s.SetRelayAcceptanceMinWait(24 * time.Hour)
+
 	if filters != nil && filters.Loopback {
 		s.SetIncludeLoopbackCandidate(true)
 	}
