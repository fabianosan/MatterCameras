<%- include('partials/header', { pageTitle: 'Options', bridgeStatus, appVersion, activePage: 'options', bridgeRestartPending }) %>

    <div class="card options-page">
        <h2>Matter hub</h2>
        <p class="field-hint" style="margin-top: 0;">
            Motion automations use <strong>OccupancySensing</strong> on the hub (e.g. SmartThings maps it to
            <em>Motion detected</em>). The bridge always reports occupancy during <code>ZoneTriggered</code>
            events. Card motion icons and routines share the same signal.
        </p>
        <p class="field-hint">
            After hub firmware or driver updates, open <strong>Matter Cameras Bridge</strong> in your hub app and
            pull down to refresh so cameras re-profile.
        </p>
    </div>

    <div class="card options-page">
        <h2>UniFi Protect controller</h2>
        <p class="field-hint" style="margin-top: 0;">
            Saved once per bridge — used for listing cameras, bulk import, and motion on UniFi cameras
            without repeating credentials in each camera record.
        </p>
        <form id="protect-controller-form" class="provider-creds options-creds">
            <label for="opt-protect-host">Controller IP / hostname</label>
            <input type="text" id="opt-protect-host" name="host" placeholder="192.168.x.x"
                value="<%= typeof protectController !== 'undefined' && protectController ? protectController.host : '' %>">
            <label for="opt-protect-user">Local user</label>
            <input type="text" id="opt-protect-user" name="username" placeholder="admin"
                value="<%= typeof protectController !== 'undefined' && protectController ? protectController.username : '' %>">
            <label for="opt-protect-pass">Password</label>
            <input type="password" id="opt-protect-pass" name="password"
                placeholder="<%= typeof protectController !== 'undefined' && protectController && protectController.hasPassword ? 'Leave blank to keep saved password' : 'password' %>">
        </form>
        <div class="options-actions">
            <button type="button" class="btn btn-sm" id="save-protect-controller-btn">Save controller login</button>
            <button type="button" class="btn btn-ghost btn-sm" id="clear-protect-controller-btn">Clear saved login</button>
        </div>
        <p id="protect-controller-status" class="field-hint"></p>
    </div>

    <div class="card options-page" id="software-updates-card">
        <h2>Software updates</h2>
        <p class="field-hint" style="margin-top: 0;">
            The bridge checks <a href="https://github.com/patricktd/MatterCameras/releases" target="_blank" rel="noopener noreferrer">GitHub Releases</a>
            for newer versions. Your camera list and Matter pairing are kept during an update.
        </p>
        <p id="software-update-status" class="field-hint">Checking for updates…</p>
        <div class="options-actions" id="software-update-actions" hidden>
            <button type="button" class="btn btn-sm" id="options-apply-update-btn" hidden>Update now</button>
            <a class="btn btn-ghost btn-sm" id="options-release-link" href="https://github.com/patricktd/MatterCameras/releases" target="_blank" rel="noopener noreferrer" hidden>Release notes</a>
        </div>
    </div>

    <div class="card options-page">
        <h2>Bridge</h2>
        <p class="field-hint" style="margin-top: 0;">
            Restart reloads all cameras and refreshes the Matter parts list for the hub after roster changes.
        </p>
        <%- include('partials/bridge-restart-form', { returnTo: '/options', bridgeRestartPending }) %>

        <div class="danger-zone">
            <h3>Reset Pairing</h3>
            <p>
                Factory-reset removes all Matter pairings. You will need to scan the QR code again.
                Your camera list is not affected.
            </p>
            <form action="/api/reset" method="POST"
                onsubmit="return confirm('WARNING: This will factory reset the Matter Bridge and remove all pairings. Are you sure?');">
                <button type="submit" class="btn btn-danger btn-sm">Reset Pairing</button>
            </form>
        </div>
    </div>

    <%- include('partials/footer') %>
    <script src="/js/options.js"></script>
