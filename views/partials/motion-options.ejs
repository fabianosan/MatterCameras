<% const motionValue = typeof selectedMotion !== 'undefined' ? selectedMotion : 'auto'; %>
<% const motionObjectTypeValue = typeof selectedMotionObjectType !== 'undefined' ? selectedMotionObjectType : 'any'; %>
<% const personSensorEnabledValue = typeof selectedPersonSensorEnabled !== 'undefined' ? selectedPersonSensorEnabled : false; %>
<% const reolinkLightEnabledValue = typeof selectedReolinkLightEnabled !== 'undefined' ? selectedReolinkLightEnabled : false; %>
<% const motionAddSource = typeof addSource !== 'undefined' ? addSource : ''; %>
<div class="motion-options-root" data-motion-root="<%= idPrefix %>" data-add-source="<%= motionAddSource %>">
    <label for="<%= idPrefix %>-motion">Motion detection</label>
    <select id="<%= idPrefix %>-motion" name="motionSource" class="motion-source-select">
        <option value="auto" <%= motionValue === 'auto' ? 'selected' : '' %>>Auto (recommended)</option>
        <option value="unifi-protect" <%= motionValue === 'unifi-protect' ? 'selected' : '' %>>UniFi Protect</option>
        <option value="reolink-native" <%= motionValue === 'reolink-native' ? 'selected' : '' %>>Reolink native</option>
        <option value="onvif" <%= motionValue === 'onvif' ? 'selected' : '' %>>ONVIF events</option>
        <option value="frame-diff" <%= motionValue === 'frame-diff' ? 'selected' : '' %>>Frame diff (any RTSP)</option>
    </select>

    <p class="field-hint motion-hint" data-show-for="auto">
        Tries UniFi Protect → Reolink → ONVIF → frame diff. When the camera type is known, only the matching settings are shown.
    </p>
    <p class="field-hint motion-hint" data-show-for="frame-diff">
        Compares low-res JPEG frames from the stream. No vendor settings required.
    </p>

    <div class="motion-field-group" data-show-for="unifi-protect auto">
        <p class="motion-group-label">UniFi Protect</p>
        <label for="<%= idPrefix %>-protect-host">Controller IP / hostname</label>
        <input type="text" id="<%= idPrefix %>-protect-host" name="protectHost"
            value="<%= typeof protectHost !== 'undefined' ? protectHost : '' %>"
            placeholder="192.168.x.x">

        <label for="<%= idPrefix %>-protect-cam">Protect camera id</label>
        <input type="text" id="<%= idPrefix %>-protect-cam" name="protectCameraId"
            value="<%= typeof protectCameraId !== 'undefined' ? protectCameraId : '' %>"
            placeholder="24-char id from Protect UI">
        <p class="field-hint">Protect app → camera → copy id from URL or device settings.</p>
    </div>

    <div class="motion-field-group" data-show-for="unifi-protect reolink-native auto">
        <p class="motion-group-label">Trigger filter</p>
        <label for="<%= idPrefix %>-motion-object-type">Trigger on</label>
        <select id="<%= idPrefix %>-motion-object-type" name="motionObjectType">
            <option value="any" <%= motionObjectTypeValue === 'any' ? 'selected' : '' %>>Any motion (current behavior)</option>
            <option value="person" <%= motionObjectTypeValue === 'person' ? 'selected' : '' %>>Person presence only</option>
        </select>
        <p class="field-hint">
            Reolink uses AI <code>people</code>. UniFi Protect uses smart person detection events.
            Matter still reports the result as motion/occupancy on SmartThings.
        </p>

        <label for="<%= idPrefix %>-person-sensor-enabled">Expose separate person presence sensor</label>
        <select id="<%= idPrefix %>-person-sensor-enabled" name="personSensorEnabled">
            <option value="false" <%= !personSensorEnabledValue ? 'selected' : '' %>>No</option>
            <option value="true" <%= personSensorEnabledValue ? 'selected' : '' %>>Yes</option>
        </select>
        <p class="field-hint">
            Adds a second Matter occupancy device in SmartThings for person-presence events, separate from the camera tile.
        </p>
    </div>

    <div class="motion-field-group" data-show-for="reolink-native auto">
        <p class="motion-group-label">Reolink</p>
        <label for="<%= idPrefix %>-reolink-ch">Channel (NVR)</label>
        <input type="number" id="<%= idPrefix %>-reolink-ch" name="reolinkChannel" min="0" max="31"
            value="<%= typeof reolinkChannel !== 'undefined' && reolinkChannel !== null ? reolinkChannel : 0 %>">
        <p class="field-hint">Use 0 for standalone cameras. RTSP credentials above are used for api.cgi.</p>

        <label for="<%= idPrefix %>-reolink-light-enabled">Expose separate light device</label>
        <select id="<%= idPrefix %>-reolink-light-enabled" name="reolinkLightEnabled">
            <option value="false" <%= !reolinkLightEnabledValue ? 'selected' : '' %>>No</option>
            <option value="true" <%= reolinkLightEnabledValue ? 'selected' : '' %>>Yes</option>
        </select>
        <p class="field-hint">
            Adds a Matter dimmable light in SmartThings for the Reolink WhiteLed (on/off and brightness) when
            <code>GetWhiteLed</code> is supported. Requires a bridge restart after enabling.
        </p>
    </div>

    <div class="motion-field-group" data-show-for="onvif auto">
        <p class="motion-group-label">ONVIF</p>
        <label for="<%= idPrefix %>-onvif">Device URL</label>
        <input type="text" id="<%= idPrefix %>-onvif" name="onvifUrl"
            value="<%= typeof onvifUrl !== 'undefined' ? onvifUrl : '' %>"
            placeholder="http://192.168.x.x:2020/onvif/device_service">
        <p class="field-hint">Tapo/Sonoff often use port 2020. Leave blank to use the RTSP host on port 80.</p>
    </div>

    <input type="hidden" id="<%= idPrefix %>-manufacturer" name="manufacturer"
        value="<%= typeof manufacturer !== 'undefined' ? manufacturer : '' %>">
    <input type="hidden" id="<%= idPrefix %>-model" name="model"
        value="<%= typeof model !== 'undefined' ? model : '' %>">
    <input type="hidden" id="<%= idPrefix %>-reolink-host" name="reolinkHost"
        value="<%= typeof reolinkHost !== 'undefined' ? reolinkHost : '' %>">
    <input type="hidden" id="<%= idPrefix %>-reolink-http-port" name="reolinkHttpPort"
        value="<%= typeof reolinkHttpPort !== 'undefined' && reolinkHttpPort !== null ? reolinkHttpPort : '' %>">
    <input type="hidden" id="<%= idPrefix %>-reolink-use-https" name="reolinkUseHttps"
        value="<%= typeof reolinkUseHttps !== 'undefined' ? String(reolinkUseHttps) : '' %>">
    <input type="hidden" id="<%= idPrefix %>-reolink-rtsp-port" name="reolinkRtspPort"
        value="<%= typeof reolinkRtspPort !== 'undefined' && reolinkRtspPort !== null ? reolinkRtspPort : '' %>">
    <input type="hidden" id="<%= idPrefix %>-reolink-protocol" name="reolinkProtocol"
        value="<%= typeof reolinkProtocol !== 'undefined' ? reolinkProtocol : '' %>">
    <input type="hidden" id="<%= idPrefix %>-reolink-stream" name="reolinkStream"
        value="<%= typeof reolinkStream !== 'undefined' ? reolinkStream : '' %>">
    <input type="hidden" id="<%= idPrefix %>-reolink-uid" name="reolinkDeviceUid"
        value="<%= typeof reolinkDeviceUid !== 'undefined' ? reolinkDeviceUid : '' %>">
    <input type="hidden" id="<%= idPrefix %>-reolink-is-nvr" name="reolinkIsNvr"
        value="<%= typeof reolinkIsNvr !== 'undefined' ? String(reolinkIsNvr) : '' %>">
    <p id="<%= idPrefix %>-motion-hint" class="field-hint motion-suggest-hint" data-show-for="auto onvif reolink-native unifi-protect"></p>
</div>
