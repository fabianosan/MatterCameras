<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MatterCameras Dashboard</title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>
    <div class="container">
        <header>
            <h1>MatterCameras</h1>
            <div id="connection-status">
                Bridge Status:
                <span
                    class="status-badge <%= bridgeStatus === 'Commissioned' ? 'status-commissioned' : 'status-ready' %>">
                    <%= bridgeStatus %>
                </span>
            </div>
        </header>
        <%- include('info-bar') %>
