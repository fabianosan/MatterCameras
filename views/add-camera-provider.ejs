<%- include('partials/header', {
    pageTitle: `Add ${selectedProvider.label}`,
    bridgeStatus,
    appVersion,
    activePage: 'add-camera',
    bodyClass: 'page-add-camera',
    extraStylesheets: ['/css/add-camera.css'],
    returnTo: `/cameras/add/${selectedProvider.id}`,
    bridgeRestartPending,
}) %>

    <div class="setup-page setup-page--provider">
        <section class="card provider-config-page">
            <div class="provider-config-page__topbar">
                <a href="/cameras/add" class="btn btn-secondary btn-sm">All Camera Types</a>
                <a href="/" class="btn btn-ghost btn-sm">Back to Dashboard</a>
            </div>

            <div class="provider-config-page__intro">
                <div>
                    <p class="section-kicker">Selected type</p>
                    <h2><%= selectedProvider.label %></h2>
                    <p class="provider-config-page__text"><%= selectedProvider.description %></p>
                </div>
            </div>

            <form action="/api/cameras" method="POST" id="add-camera-form" class="provider-form" data-provider-id="<%= selectedProvider.id %>">
                <input type="hidden" name="addSource" id="add-source" value="<%= selectedProvider.id %>">
                <input type="hidden" name="username" id="add-username" value="">
                <input type="hidden" name="password" id="add-password" value="">

                <div class="provider-form__layout">
                    <div class="provider-form__main">
                        <%- include('partials/add-camera/providers/' + selectedProvider.id, { protectController }) %>

                        <div class="provider-feedback">
                            <p id="provider-discover-status" class="field-hint provider-discover-status hidden"></p>
                            <div id="provider-discover-results" class="provider-discover-results hidden"></div>
                        </div>
                    </div>

                    <div class="provider-form__side">
                        <%- include('partials/add-camera/shared-fields', { selectedProvider, isCommissioned }) %>
                    </div>
                </div>
            </form>
        </section>
    </div>

    <script src="/js/motion-options.js"></script>
    <script src="/js/add-camera.js"></script>

    <%- include('partials/footer') %>